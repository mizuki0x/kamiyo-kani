{
  "name": "@kamiyo/kani-shim",
  "version": "0.1.1",
  "description": "JavaScript shim for teams that want to consume kamiyo-kani CI outputs without Rust integration.",
  "type": "module",
  "main": "./src/index.js",
  "types": "./src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.js"
    }
  },
  "files": [
    "src"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mizuki0x/kamiyo-kani.git",
    "directory": "packages/kamiyo-kani-js"
  },
  "publishConfig": {
    "access": "public"
  }
}
